{
    "name": "web",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "prebuild": "rimraf dist",
        "start": "npm-run-all get-theme build:sass --parallel watch:*",
        "watch:sass": "sass --watch src/site/styles:dist/styles",
        "watch:eleventy": "cross-env ELEVENTY_ENV=dev eleventy --serve --incremental",
        "build:eleventy": "cross-env ELEVENTY_ENV=prod NODE_OPTIONS=--max-old-space-size=4096 eleventy",
        "build:sass": "sass src/site/styles:dist/styles --style compressed",
        "get-theme": "node src/site/get-theme.js",
        "build": "npm-run-all get-theme build:*",
        "lint": "npm-run-all lint:*",
        "lint:js": "eslint .",
        "lint:js:fix": "eslint . --fix",
        "lint:scss": "stylelint \"src/site/styles/**/*.scss\"",
        "lint:scss:fix": "stylelint \"src/site/styles/**/*.scss\" --fix",
        "format": "prettier --write \"**/*.{js,json,md,yml,yaml,scss,css}\"",
        "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml,scss,css}\"",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.js": ["eslint --fix", "prettier --write"],
        "*.{scss,css}": ["stylelint --fix", "prettier --write"],
        "*.{json,md,yml,yaml}": ["prettier --write"]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@11ty/eleventy": "^2.0.1",
        "@11ty/eleventy-plugin-rss": "^1.2.0",
        "@eslint/js": "^10.0.1",
        "cross-env": "^10.0.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "html-minifier-terser": "^7.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "node-html-parser": "^7.0.1",
        "prettier": "^3.8.1",
        "sass": "^1.49.9",
        "stylelint": "^17.4.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0"
    },
    "dependencies": {
        "@11ty/eleventy-img": "^6.0.1",
        "@sindresorhus/slugify": "^1.1.0",
        "axios": "^1.2.2",
        "dotenv": "^17.0.0",
        "eleventy-plugin-gen-favicons": "^1.1.2",
        "eleventy-plugin-nesting-toc": "^1.3.0",
        "fs-file-tree": "^1.1.1",
        "glob": "^13.0.6",
        "gray-matter": "^4.0.3",
        "markdown-it": "^14.1.0",
        "markdown-it-anchor": "^9.0.1",
        "markdown-it-attrs": "^4.1.6",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-mark": "^4.0.0",
        "markdown-it-mathjax3": "^4.3.1",
        "markdown-it-plantuml": "^1.4.1",
        "markdown-it-task-checkbox": "^1.0.6",
        "npm-run-all": "^4.1.5",
        "rimraf": "^6.0.1",
        "sharp": "^0.34.3"
    }
}
